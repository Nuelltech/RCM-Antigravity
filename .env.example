# ================================
# BACKEND ENVIRONMENT VARIABLES
# ================================

# Server Configuration
PORT=3001
NODE_ENV=development  # Use 'production' for production deployment

# Database Configuration
# Development: Local MySQL
DATABASE_URL="mysql://root:root@localhost:3306/rcm_db"
# Production Example: Hostinger MySQL
# DATABASE_URL="mysql://user:password@host:3306/database"

# Redis Configuration (Optional)
REDIS_URL="redis://localhost:6379"
# Production Redis (if using)
# REDIS_URL="redis://host:6379"

# JWT Secrets (CHANGE THESE IN PRODUCTION!)
# Generate strong random strings: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET="super-secret-jwt-key-change-me"
JWT_REFRESH_SECRET="super-secret-refresh-key-change-me"

# Email Configuration (Hostinger SMTP)
# Note: Use mail.YOUR_DOMAIN.com, not smtp.hostinger.com
SMTP_HOST="mail.nuelltech.com"
SMTP_PORT="465"
SMTP_USER="no-reply@nuelltech.com"
SMTP_PASS="your-email-password"
EMAIL_FROM_ADDRESS="no-reply@nuelltech.com"
EMAIL_FROM_NAME="Restaurante Manager"

# Frontend URL (for email links and CORS)
# Development
FRONTEND_URL="http://localhost:3000"
# Production
# FRONTEND_URL="https://www.rcm-app.com"

# Google Cloud Vision API (for invoice OCR - Optional)
# Path to your Google Cloud service account JSON key file
# GOOGLE_VISION_API_KEY_PATH="/path/to/your/vision-api-key.json"

# Gemini AI API Key (for AI features - Optional)
# GEMINI_API_KEY="your-gemini-api-key"

# FTP Storage (Hostinger - for invoice and sales file uploads)
# If not configured, files will be stored in local filesystem as fallback
# FTP_HOST="ftp.yourdomain.com"
# FTP_USER="username@yourdomain.com"
# FTP_PASSWORD="your-ftp-password"
# FTP_PORT="21"
# FTP_BASE_PATH="/"
# FILES_PUBLIC_URL="https://yourdomain.com"

# ================================
# FRONTEND ENVIRONMENT VARIABLES
# ================================
# Create a separate .env.local file in app/frontend/ with:

# API URL
# Development: Local backend
NEXT_PUBLIC_API_URL="http://localhost:3001"
# Production: Render backend URL
# NEXT_PUBLIC_API_URL="https://rcm-nuelltech.onrender.com"

# ================================
# DEPLOYMENT NOTES
# ================================
# Render (Backend):
#   Build Command: npm install && npx prisma generate && npm run build
#   Start Command: npm start
#   Add all environment variables above (except NEXT_PUBLIC_*)
#
# Vercel (Frontend):
#   Auto-detects Next.js configuration
#   Add only: NEXT_PUBLIC_API_URL=https://rcm-nuelltech.onrender.com
#
# Remember to:
#   1. Generate new JWT secrets for production
#   2. Update FRONTEND_URL to https://www.rcm-app.com
#   3. Configure SMTP with your actual email credentials
#   4. Run database migrations after first deployment
